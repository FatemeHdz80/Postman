                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "const randomNumber = Math.floor(Math.random()*1000); \r",
                      "const repositoryName = `github api testing-${randomNumber}`; \r",
                      "pm.environment.set(`repositoryName`, repositoryName);"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const json = pm.response.json();\r",
                      "\r",
                      "pm.test(\"Status code is 201\", function () {\r",
                      "    pm.response.to.have.status(201);\r",
                      "});\r",
                      "pm.test(\"Response time is less than 3000ms\", function () {\r",
                      "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
                      "}); \r",
                      "pm.test(\"Content-Type is application/json\", function () {\r",
                      "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
                      "});  \r",
                      "pm.test(\"Description is correct\", function () {\r",
                      "    pm.expect(json.description).to.eql(\"Repository created by Postman API testing\");\r",
                      "}); \r",
                      "pm.test(\"Repository is public\", function() {\r",
                      "    pm.expect(json.private).to.be.false;\r",
                      "}); \r",
                      "pm.test(\"Owner is correct\", function () {\r",
                      "    pm.expect(json.owner.login).to.eql(pm.environment.get(\"username\"));\r",
                      "}); \r",
                      "pm.test(\"Default branch is main\", function () {\r",
                      "    pm.expect(json.default_branch).to.eql(\"main\");\r",
                      "}); \r",
                      "pm.test(\"Visibility is public\", function () {\r",
                      "    pm.expect(json.visibility).to.eql(\"public\");\r",
                      "}); \r",
                      "pm.test(\"Repository id is number\", function () {\r",
                      "    pm.expect(json.id).to.be.a(\"number\");\r",
                      "}); \r",
                      "pm.environment.set(\"repositoryName\", pm.response.json().name);"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
