            {
              "name": "Get User",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const json = pm.response.json();\r",
                      "\r",
                      "pm.test(\"Status code is 200\", function () {\r",
                      "    pm.response.to.have.status(200); \r",
                      "}); \r",
                      "pm.test(\"Response has login property\", function () {\r",
                      "    pm.expect(json).to.have.property(\"login\");\r",
                      "});\r",
                      "pm.test(\"id is a number\", function() {\r",
                      "    pm.expect(json.id).to.be.a(\"number\")\r",
                      "});  \r",
                      "pm.test(\"node_id is string\", function () {\r",
                      "    pm.expect(json.node_id).to.be.a(\"string\");\r",
                      "});\r",
                      "pm.test(\"Username is correct\", function () {\r",
                      "    pm.expect(json.login).to.eql(pm.environment.get(\"username\"));\r",
                      "});\r",
                      "pm.test(\"Type is User\", function() {\r",
                      "    pm.expect(json.type).to.eql(\"User\");\r",
                      "});\r",
                      "pm.test(\"followers is a number\", function() {\r",
                      "    pm.expect(json.followers).to.be.a(\"number\")\r",
                      "}); \r",
                      "pm.test(\"Followers count is not negative\", function () {\r",
                      "    pm.expect(json.followers).to.be.at.least(0);\r",
                      "}); \r",
                      "pm.test(\"site_admin is false\", function () {\r",
                      "    pm.expect(json.site_admin).to.be.false;\r",
                      "}); \r",
                      "pm.test(\"bio is string or null\", function () {\r",
                      "    pm.expect(json.bio === null || typeof json.bio === \"string\").to.be.true;\r",
                      "}); \r",
                      "pm.test(\"Content-Type is application/json\", function () {\r",
                      "    pm.expect(pm.response.headers.get(\"Content-Type\"))\r",
                      "    .to.include(\"application/json\");\r",
                      "});"
